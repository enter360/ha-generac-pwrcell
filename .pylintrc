[FORMAT]
# sensor.py uses aligned multi-column tables in SENSOR_DESCRIPTIONS
max-line-length=140

[DESIGN]
# coordinator.__init__ and auth._async_request each have 6 params (inc. self)
max-positional-arguments=6
# PWRcellIntegratedEnergySensor.__init__ has 7 non-self params
max-args=8
# _parse_homes and _parse_telemetry unpack many device fields
max-locals=25
# conftest._SensorEntityDescription has 11 attributes
max-attributes=11

[MESSAGES CONTROL]
disable=
    # Tests intentionally access private coordinator/auth internals
    protected-access,
    # Coordinators and config-flow classes expose one public entry point by design
    too-few-public-methods,
    # Broad catches are intentional graceful-degradation in coordinator/config_flow
    broad-exception-caught,
    # Docstrings not required for short property/helper methods
    missing-function-docstring,
    # == {} in tests is clearer intent than `not x`
    use-implicit-booleaness-not-comparison,
    # pytest.raises imports inside test functions are a standard pattern
    import-outside-toplevel,
